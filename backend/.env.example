# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/dealvault

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ─── Docker / MongoDB (used in docker-compose) ─────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=replace_with_secure_password

# ─── GitHub App (DealVault Bot) ────────────────────────────────────────────────
# Create a GitHub App at https://github.com/settings/apps/new
# See docs/github-bot-setup.md for step-by-step instructions
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=          # Base64-encoded private key (or raw PEM)
GITHUB_WEBHOOK_SECRET=           # Webhook secret configured in GitHub App
GITHUB_APP_INSTALLATION_ID=      # Installation ID (from org install page)

# ─── DealVault Platform ────────────────────────────────────────────────────────
PLATFORM_BASE_URL=http://localhost:3000